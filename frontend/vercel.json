{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/update-weather",
      "schedule": "0 12 * * *"
    }
  ],
  "functions": {
    "app/api/update-weather/route.js": {
      "maxDuration": 30
    },
    "app/api/get-cached-weather/route.js": {
      "maxDuration": 10
    }
  }
}